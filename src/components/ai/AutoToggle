'use client'
 
import { useState, useEffect } from 'react'
import { motion, AnimatePresence } from 'framer-motion'
import { 
  Tag, 
  X, 
  Plus, 
  Search, 
  Filter,
  Zap,
  Sparkles,
  Trash2,
  Edit3,
  CheckCircle,
  Clock,
  Image as ImageIcon,
  Folder,
  Palette,
  Users,
  Star,
  TrendingUp
} from 'lucide-react'
import { Button } from '@/components/ui/Button'
import { Input } from '@/components/ui/Input'
import { Textarea } from '@/components/ui/Textarea'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/Select'
import { Modal } from '@/components/ui/Modal'
import { LoadingSpinner } from '@/components/ui/LoadingSpinner'
import { cn } from '@/components/ui/utils'
 
interface AutoTaggingProps {
  isOpen: boolean
  onClose: () => void
  imageId?: string
}
 
interface TagCategory {
  id: string
  name: string
  color: string
  icon?: React.ReactNode
}
 
interface AutoTag {
  id: string
  name: string
  category: string
  confidence: number
  suggested: boolean
  applied: boolean
}
 
interface TagRule {
  id: string
  name: string
  condition: {
    field: string
    operator: 'contains' | 'matches' | 'greater' | 'less'
    value: string
  }
  tags: string[]
  enabled: boolean
  lastTriggered?: string
}
 
interface TagStats {
  totalTags: number
  appliedTags: number
  averageConfidence: number
  categoriesUsed: number
  topTags: Array<{
    name: string
    count: number
    percentage: number
  }>
}
 
const tagCategories: TagCategory[] = [
  { id: 'style', name: 'Style', color: 'purple', icon: <Palette className="w-4 h-4" /> },
  { id: 'content', name: 'Content', color: 'blue', icon: <ImageIcon className="w-4 h-4" /> },
  { id: 'mood', name: 'Mood', color: 'green', icon: <Sparkles className="w-4 h-4" /> },
  { id: 'people', name: 'People', color: 'red', icon: <Users className="w-4 h-4" /> },
  { id: 'objects', name: 'Objects', color: 'yellow', icon: <Zap className="w-4 h-4" /> },
  { id: 'abstract', name: 'Abstract', color: 'gray', icon: <TrendingUp className="w-4 h-4" /> }
]
 
const tagSuggestions: AutoTag[] = [
  { id: '1', name: 'cyberpunk', category: 'style', confidence: 0.95, suggested: true, applied: false },
  { id: '2', name: 'neon', category: 'style', confidence: 0.88, suggested: true, applied: false },
  { id: '3', name: 'futuristic', category: 'mood', confidence: 0.92, suggested: true, applied: false },
  { id: '4', name: 'cityscape', category: 'content', confidence: 0.87, suggested: true, applied: false },
  { id: '5', name: 'night', category: 'mood', confidence: 0.78, suggested: true, applied: false },
  { id: '6', name: 'buildings', category: 'objects', confidence: 0.83, suggested: true, applied: false },
  { id: '7', name: 'glowing', category: 'style', confidence: 0.76, suggested: true, applied: false },
  { id: '8', name: 'dark', category: 'mood', confidence: 0.71, suggested: true, applied: false }
]
 
const mockRules: TagRule[] = [
  {
    id: '1',
    name: 'Night Scenes',
    condition: {
      field: 'brightness',
      operator: 'less',
      value: '0.3'
    },
    tags: ['night', 'dark', 'noir'],
    enabled: true,
    lastTriggered: new Date().toISOString()
  },
  {
    id: '2',
    name: 'Portrait Mode',
    condition: {
      field: 'content',
      operator: 'contains',
      value: 'person'
    },
    tags: ['portrait', 'people', 'face'],
    enabled: true,
    lastTriggered: new Date(Date.now() - 3600000).toISOString()
  },
  {
    id: '3',
    name: 'High Quality',
    condition: {
      field: 'resolution',
      operator: 'greater',
      value: '1920'
    },
    tags: ['high-quality', 'hd', 'ultra-hd'],
    enabled: false,
    lastTriggered: new Date(Date.now() - 86400000).toISOString()
  }
]
 
const mockStats: TagStats = {
  totalTags: 1250,
  appliedTags: 875,
  averageConfidence: 0.82,
  categoriesUsed: 6,
  topTags: [
    { name: 'cyberpunk', count: 156, percentage: 12.5 },
    { name: 'portrait', count: 142, percentage: 11.4 },
    { name: 'abstract', count: 128, percentage: 10.2 },
    { name: 'landscape', count: 115, percentage: 9.2 },
    { name: 'neon', count: 98, percentage: 7.8 }
  ]
}
 
export const AutoTagging = ({ isOpen, onClose, imageId }: AutoTaggingProps) => {
  const [activeTab, setActiveTab] = useState<'suggestions' | 'rules' | 'stats'>('suggestions')
  const [suggestions, setSuggestions] = useState<AutoTag[]>(tagSuggestions)
  const [rules, setRules] = useState<TagRule[]>(mockRules)
  const [stats, setStats] = useState<TagStats>(mockStats)
  const [newRule, setNewRule] = useState({
    name: '',
    condition: {
      field: 'brightness',
      operator: 'contains',
      value: ''
    },
    tags: ''
  })
  const [searchTerm, setSearchTerm] = useState('')
  const [selectedCategory, setSelectedCategory] = useState<string>('all')
  const [isProcessing, setIsProcessing] = useState(false)
  const [customTags, setCustomTags] = useState<string[]>([])
  const [newCustomTag, setNewCustomTag] = useState('')
 
  useEffect(() => {
    if (isOpen) {
      analyzeImage()
    }
  }, [isOpen])
 
  const analyzeImage = async () => {
    setIsProcessing(true)
    try {
      // Simulate AI analysis
      await new Promise(resolve => setTimeout(resolve, 2000))
      
      // Update suggestions with random confidence scores
      setSuggestions(prev => prev.map(tag => ({
        ...tag,
        confidence: 0.7 + Math.random() * 0.3,
        suggested: true
      })))
    } catch (error) {
      console.error('Error analyzing image:', error)
    } finally {
      setIsProcessing(false)
    }
  }
 
  const applyTag = (tagId: string) => {
    setSuggestions(prev => prev.map(tag => 
      tag.id === tagId ? { ...tag, applied: !tag.applied } : tag
    ))
  }
 
  const createRule = () => {
    if (!newRule.name || !newRule.condition.value) return
 
    const rule: TagRule = {
      id: Date.now().toString(),
      name: newRule.name,
      condition: newRule.condition,
      tags: newRule.tags.split(',').map(tag => tag.trim()).filter(tag => tag),
      enabled: true
    }
 
    setRules(prev => [rule, ...prev])
    setNewRule({
      name: '',
      condition: {
        field: 'brightness',
        operator: 'contains',
        value: ''
      },
      tags: ''
    })
  }
 
  const deleteRule = (ruleId: string) => {
    setRules(prev => prev.filter(rule => rule.id !== ruleId))
  }
 
  const toggleRule = (ruleId: string) => {
    setRules(prev => prev.map(rule => 
      rule.id === ruleId ? { ...rule, enabled: !rule.enabled } : rule
    ))
  }
 
  const addCustomTag = () => {
    if (newCustomTag.trim() && !customTags.includes(newCustomTag.trim())) {
      setCustomTags(prev => [...prev, newCustomTag.trim()])
      setNewCustomTag('')
    }
  }
 
  const removeCustomTag = (tag: string) => {
    setCustomTags(prev => prev.filter(t => t !== tag))
  }
 
  const filteredSuggestions = suggestions.filter(tag => {
    const matchesSearch = tag.name.toLowerCase().includes(searchTerm.toLowerCase())
    const matchesCategory = selectedCategory === 'all' || tag.category === selectedCategory
    return matchesSearch && matchesCategory
  })
 
  return (
    <Modal
      isOpen={isOpen}
      onClose={onClose}
      title="AI Auto-Tagging & Categorization"
      size="full"
      className="max-w-6xl"
      loading={isProcessing}
    >
      <div className="space-y-6">
        {/* Header */}
        <div className="flex items-center justify-between">
          <div>
            <h2 className="text-2xl font-bold text-cyan-400">Smart Tagging</h2>
            <p className="text-gray-400">
              AI-powered image analysis and auto-tagging
            </p>
          </div>
          
          <div className="flex items-center space-x-2">
            <Button variant="outline" onClick={analyzeImage} disabled={isProcessing}>
              {isProcessing ? (
                <>
                  <LoadingSpinner size="sm" className="mr-2" />
                  Analyzing...
                </>
              ) : (
                <>
                  <Sparkles className="w-4 h-4 mr-2" />
                  Re-analyze
                </>
              )}
            </Button>
          </div>
        </div>
 
        {/* Stats Overview */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
            <div className="flex items-center space-x-3">
              <Tag className="w-6 h-6 text-cyan-400" />
              <div>
                <p className="text-sm text-gray-400">Total Tags</p>
                <p className="text-2xl font-bold text-white">{stats.totalTags}</p>
              </div>
            </div>
          </div>
          
          <div className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
            <div className="flex items-center space-x-3">
              <CheckCircle className="w-6 h-6 text-green-400" />
              <div>
                <p className="text-sm text-gray-400">Applied</p>
                <p className="text-2xl font-bold text-white">{stats.appliedTags}</p>
              </div>
            </div>
          </div>
          
          <div className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
            <div className="flex items-center space-x-3">
              <Star className="w-6 h-6 text-yellow-400" />
              <div>
                <p className="text-sm text-gray-400">Confidence</p>
                <p className="text-2xl font-bold text-white">
                  {Math.round(stats.averageConfidence * 100)}%
                </p>
              </div>
            </div>
          </div>
          
          <div className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
            <div className="flex items-center space-x-3">
              <Folder className="w-6 h-6 text-purple-400" />
              <div>
                <p className="text-sm text-gray-400">Categories</p>
                <p className="text-2xl font-bold text-white">{stats.categoriesUsed}</p>
              </div>
            </div>
          </div>
        </div>
 
        {/* Tabs */}
        <div className="flex items-center space-x-4 border-b border-gray-700">
          <button
            onClick={() => setActiveTab('suggestions')}
            className={cn(
              'px-4 py-2 font-medium transition-colors',
              activeTab === 'suggestions'
                ? 'text-cyan-400 border-b-2 border-cyan-400'
                : 'text-gray-400 hover:text-gray-300'
            )}
          >
            AI Suggestions
          </button>
          <button
            onClick={() => setActiveTab('rules')}
            className={cn(
              'px-4 py-2 font-medium transition-colors',
              activeTab === 'rules'
                ? 'text-cyan-400 border-b-2 border-cyan-400'
                : 'text-gray-400 hover:text-gray-300'
            )}
          >
            Tag Rules
          </button>
          <button
            onClick={() => setActiveTab('stats')}
            className={cn(
              'px-4 py-2 font-medium transition-colors',
              activeTab === 'stats'
                ? 'text-cyan-400 border-b-2 border-cyan-400'
                : 'text-gray-400 hover:text-gray-300'
            )}
          >
            Statistics
          </button>
        </div>
 
        {/* Tab Content */}
        <AnimatePresence mode="wait">
          {activeTab === 'suggestions' && (
            <motion.div
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: -20 }}
              className="space-y-4"
            >
              {/* Filters */}
              <div className="flex items-center space-x-4">
                <div className="relative flex-1 max-w-md">
                  <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" />
                  <Input
                    value={searchTerm}
                    onChange={(e) => setSearchTerm(e.target.value)}
                    placeholder="Search tags..."
                    className="pl-9"
                  />
                </div>
                
                <Select
                  value={selectedCategory}
                  onValueChange={setSelectedCategory}
                >
                  <SelectTrigger className="w-48">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">All Categories</SelectItem>
                    {tagCategories.map(category => (
                      <SelectItem key={category.id} value={category.id}>
                        {category.icon} {category.name}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
 
              {/* Tag Suggestions */}
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {filteredSuggestions.map((tag) => {
                  const category = tagCategories.find(c => c.id === tag.category)
                  return (
                    <motion.div
                      key={tag.id}
                      whileHover={{ y: -2 }}
                      className={cn(
                        'p-4 rounded-lg border-2 transition-all duration-200',
                        tag.applied
                          ? 'bg-cyan-500/10 border-cyan-400'
                          : 'bg-gray-800 border-gray-700 hover:border-gray-600'
                      )}
                    >
                      <div className="flex items-center justify-between mb-2">
                        <div className="flex items-center space-x-2">
                          {category?.icon}
                          <span className="font-medium text-white">{tag.name}</span>
                          {tag.suggested && (
                            <span className="text-xs text-cyan-400">AI</span>
                          )}
                        </div>
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={() => applyTag(tag.id)}
                        >
                          {tag.applied ? (
                            <CheckCircle className="w-4 h-4 text-green-400" />
                          ) : (
                            <Plus className="w-4 h-4" />
                          )}
                        </Button>
                      </div>
                      
                      <div className="flex items-center justify-between text-xs">
                        <span className="text-gray-400">{category?.name}</span>
                        <div className="flex items-center space-x-2">
                          <div className="w-16 bg-gray-700 rounded-full h-1">
                            <motion.div
                              className="h-1 rounded-full bg-gradient-to-r from-cyan-400 to-blue-400"
                              initial={{ width: 0 }}
                              animate={{ width: `${tag.confidence * 100}%` }}
                            />
                          </div>
                          <span className="text-cyan-400">
                            {Math.round(tag.confidence * 100)}%
                          </span>
                        </div>
                      </div>
                    </motion.div>
                  )
                })}
              </div>
 
              {/* Custom Tags */}
              <div className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
                <h3 className="text-sm font-medium text-gray-300 mb-3">Custom Tags</h3>
                <div className="flex items-center space-x-2 mb-3">
                  <Input
                    value={newCustomTag}
                    onChange={(e) => setNewCustomTag(e.target.value)}
                    placeholder="Add custom tag..."
                    onKeyPress={(e) => e.key === 'Enter' && addCustomTag()}
                  />
                  <Button onClick={addCustomTag}>
                    <Plus className="w-4 h-4" />
                  </Button>
                </div>
                
                <div className="flex flex-wrap gap-2">
                  {customTags.map((tag, index) => (
                    <span
                      key={index}
                      className="flex items-center space-x-1 px-3 py-1 bg-gray-700 text-gray-300 rounded-full text-sm"
                    >
                      <span>{tag}</span>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => removeCustomTag(tag)}
                        className="p-0 h-auto w-auto"
                      >
                        <X className="w-3 h-3" />
                      </Button>
                    </span>
                  ))}
                </div>
              </div>
            </motion.div>
          )}
 
          {activeTab === 'rules' && (
            <motion.div
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: -20 }}
              className="space-y-4"
            >
              {/* Create Rule */}
              <div className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
                <h3 className="text-lg font-medium text-white mb-4">Create Tagging Rule</h3>
                
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-2">Rule Name</label>
                    <Input
                      value={newRule.name}
                      onChange={(e) => setNewRule(prev => ({ ...prev, name: e.target.value }))}
                      placeholder="e.g., Night Scenes"
                    />
                  </div>
                  
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-2">Condition</label>
                    <Select
                      value={newRule.condition.field}
                      onValueChange={(field) => 
                        setNewRule(prev => ({ 
                          ...prev, 
                          condition: { ...prev.condition, field }
                        }))
                      }
                    >
                      <SelectTrigger>
                        <SelectValue />
                      </SelectTrigger>
                      <SelectContent>
                        <SelectItem value="brightness">Brightness</SelectItem>
                        <SelectItem value="content">Content</SelectItem>
                        <SelectItem value="resolution">Resolution</SelectItem>
                        <SelectItem value="style">Style</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>
                  
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-2">Operator</label>
                    <Select
                      value={newRule.condition.operator}
                      onValueChange={(operator: any) => 
                        setNewRule(prev => ({ 
                          ...prev, 
                          condition: { ...prev.condition, operator }
                        }))
                      }
                    >
                      <SelectTrigger>
                        <SelectValue />
                      </SelectTrigger>
                      <SelectContent>
                        <SelectItem value="contains">Contains</SelectItem>
                        <SelectItem value="matches">Matches</SelectItem>
                        <SelectItem value="greater">Greater Than</SelectItem>
                        <SelectItem value="less">Less Than</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>
                  
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-2">Value</label>
                    <Input
                      value={newRule.condition.value}
                      onChange={(e) => 
                        setNewRule(prev => ({ 
                          ...prev, 
                          condition: { ...prev.condition, value: e.target.value }
                        }))
                      }
                      placeholder="e.g., 0.3"
                    />
                  </div>
                </div>
                
                <div className="mt-4">
                  <label className="block text-sm font-medium text-gray-300 mb-2">Tags (comma-separated)</label>
                  <Input
                    value={newRule.tags}
                    onChange={(e) => setNewRule(prev => ({ ...prev, tags: e.target.value }))}
                    placeholder="night, dark, noir"
                  />
                </div>
                
                <Button onClick={createRule} className="mt-4">
                  Create Rule
                </Button>
              </div>
 
              {/* Existing Rules */}
              <div className="space-y-3">
                {rules.map((rule) => (
                  <motion.div
                    key={rule.id}
                    whileHover={{ y: -2 }}
                    className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg"
                  >
                    <div className="flex items-center justify-between mb-3">
                      <div className="flex items-center space-x-3">
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={() => toggleRule(rule.id)}
                          className={cn(
                            rule.enabled ? 'text-green-400' : 'text-gray-400'
                          )}
                        >
                          {rule.enabled ? (
                            <CheckCircle className="w-4 h-4" />
                          ) : (
                            <XCircle className="w-4 h-4" />
                          )}
                        </Button>
                        <div>
                          <h3 className="font-medium text-white">{rule.name}</h3>
                          <p className="text-sm text-gray-400">
                            {rule.condition.field} {rule.condition.operator} {rule.condition.value}
                          </p>
                        </div>
                      </div>
                      
                      <div className="flex items-center space-x-2">
                        <Button variant="ghost" size="sm">
                          <Edit3 className="w-4 h-4" />
                        </Button>
                        <Button variant="ghost" size="sm" onClick={() => deleteRule(rule.id)}>
                          <Trash2 className="w-4 h-4" />
                        </Button>
                      </div>
                    </div>
                    
                    <div className="flex items-center justify-between text-sm">
                      <div className="flex flex-wrap gap-1">
                        {rule.tags.map((tag, index) => (
                          <span key={index} className="px-2 py-1 bg-cyan-500/20 text-cyan-400 rounded">
                            {tag}
                          </span>
                        ))}
                      </div>
                      
                      {rule.lastTriggered && (
                        <span className="text-gray-400">
                          Last triggered: {new Date(rule.lastTriggered).toLocaleDateString()}
                        </span>
                      )}
                    </div>
                  </motion.div>
                ))}
              </div>
            </motion.div>
          )}
 
          {activeTab === 'stats' && (
            <motion.div
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: -20 }}
              className="space-y-6"
            >
              {/* Top Tags */}
              <div>
                <h3 className="text-lg font-medium text-white mb-4">Most Used Tags</h3>
                <div className="space-y-3">
                  {stats.topTags.map((tag, index) => (
                    <div key={index} className="flex items-center justify-between">
                      <div className="flex items-center space-x-3">
                        <span className="text-sm font-medium text-white">#{tag.name}</span>
                        <span className="text-xs text-gray-400">{tag.count} uses</span>
                      </div>
                      <div className="flex items-center space-x-2">
                        <div className="w-24 bg-gray-700 rounded-full h-2">
                          <motion.div
                            className="h-2 rounded-full bg-gradient-to-r from-cyan-400 to-blue-400"
                            initial={{ width: 0 }}
                            animate={{ width: `${tag.percentage}%` }}
                          />
                        </div>
                        <span className="text-sm text-gray-400">{tag.percentage}%</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
 
              {/* Category Distribution */}
              <div>
                <h3 className="text-lg font-medium text-white mb-4">Category Distribution</h3>
                <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
                  {tagCategories.map((category) => (
                    <div key={category.id} className="p-4 bg-gray-800/50 border border-gray-700 rounded-lg">
                      <div className="flex items-center space-x-2 mb-2">
                        {category.icon}
                        <span className="font-medium text-white">{category.name}</span>
                      </div>
                      <div className="text-2xl font-bold text-cyan-400">
                        {Math.round(Math.random() * 100)}%
                      </div>
                      <div className="text-xs text-gray-400">
                        of all tags
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </Modal>
  )
}
